    {
      "name": "5. Create Student (ADMIN ONLY)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log('Using Admin Token for Create...');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\n",
              "const studentId = response.id;\n",
              "\n",
              "// Store student ID for later use\n",
              "pm.environment.set('student_id_1', studentId);\n",
              "\n",
              "console.log('✓ Student Created with ID: ' + studentId);\n",
              "pm.test('Student created successfully', () => {\n",
              "  pm.expect(pm.response.code).to.equal(201);\n",
              "  pm.expect(response).to.have.property('id');\n",
              "  pm.expect(response).to.have.property('name');\n",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/student",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["student"]
        }
      },
      "response": []
    },
