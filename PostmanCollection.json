    {
      "name": "3. Login as Admin (Get JWT Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response\n",
              "const response = pm.response.json();\n",
              "const token = response.token;\n",
              "\n",
              "// Store token in environment\n",
              "pm.environment.set('jwt_token', token);\n",
              "pm.environment.set('admin_token', token);\n",
              "\n",
              "console.log('✓ Admin Token Stored: ' + token.substring(0, 20) + '...');\n",
              "pm.test('Login successful - Token received', () => {\n",
              "  pm.expect(response).to.have.property('token');\n",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
